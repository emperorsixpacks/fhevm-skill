# Wallet mnemonic for deployment (NEVER commit the real one)
MNEMONIC="test test test test test test test test test test test junk"

# Infura API key for Sepolia RPC access
# Get one at: https://www.infura.io/
INFURA_API_KEY="your_infura_api_key_here"

# Etherscan API key for contract verification
# Get one at: https://etherscan.io/apis
ETHERSCAN_API_KEY="your_etherscan_api_key_here"

# Alternative: use Hardhat vars instead of .env
# npx hardhat vars set MNEMONIC "your mnemonic here"
# npx hardhat vars set INFURA_API_KEY "your key here"
# npx hardhat vars set ETHERSCAN_API_KEY "your key here"

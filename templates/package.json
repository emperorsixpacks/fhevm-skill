{
  "name": "fhevm-project",
  "version": "1.0.0",
  "private": true,
  "description": "Confidential smart contract project using Zama FHEVM",
  "engines": {
    "node": ">=20",
    "npm": ">=9"
  },
  "scripts": {
    "build": "hardhat compile",
    "clean": "hardhat clean && rimraf artifacts cache types",
    "compile": "hardhat compile",
    "deploy": "hardhat deploy",
    "deploy:sepolia": "hardhat deploy --network sepolia",
    "test": "hardhat test",
    "test:sepolia": "hardhat test --network sepolia",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "format": "prettier --write 'contracts/**/*.sol' 'test/**/*.ts' 'deploy/**/*.ts'",
    "typechain": "hardhat typechain",
    "verify": "hardhat verify --network sepolia"
  },
  "dependencies": {
    "@fhevm/mock-utils": "^0.4.2",
    "@fhevm/solidity": "^0.11.1",
    "@openzeppelin/contracts": "^5.1.0",
    "@openzeppelin/confidential-contracts": "^0.4.0",
    "encrypted-types": "^0.0.4"
  },
  "devDependencies": {
    "@fhevm/hardhat-plugin": "^0.4.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@zama-fhe/relayer-sdk": "^0.4.1",
    "chai": "^4.5.0",
    "chai-as-promised": "^8.0.2",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.4",
    "hardhat-deploy": "^0.11.45",
    "hardhat-gas-reporter": "^2.3.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "prettier-plugin-solidity": "^2.2.1",
    "rimraf": "^6.1.2",
    "solhint": "^6.0.3",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  }
}

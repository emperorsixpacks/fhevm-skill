{
  "name": "fhevm-setup",
  "version": "1.0.3",
  "description": "Install the FHEVM skill for AI agents (Kiro, Cursor, Windsurf, Copilot, Claude)",
  "bin": {
    "fhevm-setup": "dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "copy-skill": "node -e \"const fs=require('fs-extra'); fs.copySync('../SKILL.md','skill/SKILL.md'); fs.copySync('../references','skill/references'); fs.copySync('../examples','skill/examples'); fs.copySync('../templates','skill/templates');\"",
    "prepublishOnly": "npm run copy-skill && npm run build"
  },
  "files": [
    "dist",
    "skill",
    "README.md"
  ],
  "dependencies": {
    "commander": "12.1.0",
    "fs-extra": "11.2.0",
    "picocolors": "1.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/node": "20.14.0",
    "typescript": "5.5.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
